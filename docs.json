{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Skills API",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4338CA"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Skills",
            "pages": [
              "api-reference/endpoint/search"
            ]
          },
          {
            "group": "Selected Skills",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete"
            ]
          },
          {
            "group": "Admin",
            "pages": [
              "api-reference/endpoint/counts"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Swagger UI",
          "href": "http://localhost:5000/api-docs",
          "icon": "brackets-curly"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/your-org/skills-api",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@yourcompany.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Swagger UI",
      "href": "http://localhost:5000/api-docs"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/your-org/skills-api"
    }
  }
}